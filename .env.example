# ── MQTT ──────────────────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=home/sensors

# ── InfluxDB ──────────────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=home
INFLUXDB_BUCKET_RAW=sensors-raw
INFLUXDB_BUCKET_HOURLY=sensors-hourly
INFLUXDB_BUCKET_DAILY=sensors-daily

# ── Rachio ────────────────────────────────────────────────────────────
RACHIO_API_KEY=
RACHIO_DEVICE_ID=

# ── Dashboard ─────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:5050/api/ingest/environmental-station

# ── Station Info ──────────────────────────────────────────────────────
STATION_ID=berkeley-hilltop
STATION_LAT=37.8696
STATION_LON=-122.2491
STATION_ELEVATION=161.1

# ── Alert Thresholds ─────────────────────────────────────────────────
DIABLO_SPEED_THRESHOLD=25
DIABLO_HUMIDITY_THRESHOLD=20
AQI_ALERT_THRESHOLD=100
AQI_CRITICAL_THRESHOLD=200
SOIL_DRY_THRESHOLD=25
SOIL_WET_THRESHOLD=85
SOIL_CRITICAL_THRESHOLD=95
RAIN_HEAVY_RATE=10
RAIN_EXTREME_RATE=25

# ── Telemetry / API ──────────────────────────────────────────────────
HEARTBEAT_INTERVAL_SEC=60
LOG_LEVEL=INFO
API_PORT=8090

# ── MQTT Zone Mapping (JSON) ─────────────────────────────────────────
ZONE_MAPPING={"zone_front":"rachio-zone-id-1","zone_hillside":"rachio-zone-id-2"}
